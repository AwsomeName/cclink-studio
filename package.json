{
  "name": "cclink-studio",
  "productName": "CCLink Studio 开源版",
  "version": "0.1.1",
  "packageManager": "pnpm@11.5.0",
  "description": "An open-source AI-powered desktop workspace — embedded browser, document editor, and AI agent, all in one.",
  "main": "./out/main/index.js",
  "private": false,
  "license": "GPL-3.0-only",
  "author": "CCLink Studio Contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AwsomeName/cclink-studio.git"
  },
  "homepage": "https://github.com/AwsomeName/cclink-studio#readme",
  "bugs": {
    "url": "https://github.com/AwsomeName/cclink-studio/issues"
  },
  "scripts": {
    "start": "bash scripts/restart.sh start",
    "stop": "bash scripts/restart.sh stop",
    "studio": "bash scripts/studio.sh",
    "studio:start": "bash scripts/studio.sh start",
    "studio:status": "bash scripts/studio.sh status",
    "studio:logs": "bash scripts/studio.sh logs",
    "studio:stop": "bash scripts/studio.sh stop",
    "studio:smoke": "bash scripts/studio.sh smoke",
    "studio:package": "bash scripts/studio.sh package",
    "dev": "ELECTRON_RUN_AS_NODE= bash scripts/dev.sh",
    "build": "pnpm typecheck && electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "node scripts/ensure-electron-runtime.mjs && electron-builder install-app-deps",
    "prepackage": "pnpm build && pnpm stage:agent-runtime",
    "package": "electron-builder",
    "package:dev": "pnpm stage:agent-runtime && electron-builder --config.compression=store",
    "release": "bash scripts/package.sh",
    "release:arm64": "bash scripts/package.sh --arm64",
    "release:x64": "bash scripts/package.sh --x64",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck": "pnpm typecheck:web && pnpm typecheck:node",
    "verify:oss-boundary": "node scripts/verify-oss-boundary.mjs",
    "verify:context-actions": "node scripts/verify-context-action-boundary.mjs",
    "stage:agent-runtime": "node scripts/stage-claude-runtime.mjs",
    "verify:agent-runtime": "node scripts/stage-claude-runtime.mjs --verify-only",
    "smoke:agent-runtime": "node scripts/smoke-claude-runtime.mjs",
    "verify": "pnpm verify:oss-boundary && pnpm verify:context-actions && pnpm format:check && pnpm lint && pnpm test && pnpm build",
    "smoke:local": "node scripts/local-smoke.mjs",
    "smoke:ui": "node scripts/ui-smoke.mjs",
    "smoke:workflow": "node scripts/workflow-smoke.mjs",
    "smoke:restore": "node scripts/restore-smoke.mjs",
    "smoke:auth-window": "node scripts/auth-window-smoke.cjs",
    "smoke:standalone": "pnpm smoke:local && pnpm smoke:ui && pnpm smoke:workflow && pnpm smoke:restore",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.{ts,tsx,css}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,css}'",
    "dev:bg": "bash scripts/restart.sh start",
    "dev:stop": "bash scripts/restart.sh stop",
    "dev:status": "bash scripts/restart.sh status",
    "dev:logs": "bash scripts/restart.sh logs",
    "restart": "bash scripts/restart.sh",
    "restart:dev": "bash scripts/restart.sh"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.211",
    "@anthropic-ai/sdk": "^0.111.0",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tiptap/core": "^3.25.0",
    "@tiptap/extension-code-block-lowlight": "^3.25.0",
    "@tiptap/extension-image": "^3.25.0",
    "@tiptap/extension-link": "^3.25.0",
    "@tiptap/extension-placeholder": "^3.25.0",
    "@tiptap/extension-table": "^3.25.0",
    "@tiptap/extension-table-cell": "^3.25.0",
    "@tiptap/extension-table-header": "^3.25.0",
    "@tiptap/extension-table-row": "^3.25.0",
    "@tiptap/extension-task-item": "^3.25.0",
    "@tiptap/extension-task-list": "^3.25.0",
    "@tiptap/markdown": "^3.25.0",
    "@tiptap/pm": "^3.25.0",
    "@tiptap/react": "^3.25.0",
    "@tiptap/starter-kit": "^3.25.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "@yume-chan/adb": "^2.6.0",
    "@yume-chan/adb-scrcpy": "^2.3.2",
    "@yume-chan/event": "^2.0.0",
    "@yume-chan/scrcpy": "^2.3.0",
    "@yume-chan/scrcpy-decoder-webcodecs": "^2.5.3",
    "@yume-chan/stream-extra": "^2.5.3",
    "agent-device": "^0.17.2",
    "fast-xml-parser": "^5.8.0",
    "fflate": "^0.8.3",
    "highlight.js": "^11.11.1",
    "juice": "^12.1.0",
    "lowlight": "^3.3.0",
    "markdown-it": "^14.2.0",
    "mermaid": "^11.16.0",
    "node-pty": "^1.1.0",
    "occt-import-js": "^0.0.23",
    "playwright-core": "^1.52.0",
    "three": "^0.185.1",
    "yauzl": "^3.3.2",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "@types/yauzl": "^3.3.0",
    "@vitejs/plugin-react": "^4.6.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^6.3.5",
    "vitest": "^3.2.6"
  }
}
